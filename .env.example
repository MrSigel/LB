# Vorlage für den Mailversand des Kontaktformulars.
# Kopieren nach .env.local und ausfüllen – .env.local ist per .gitignore
# ausgeschlossen und gehört NICHT ins Repository.

# SMTP-Zugang des Postfachs, das die Mails verschickt
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@limit-breakers.eu
SMTP_PASS=

# Optional: true erzwingt TLS ab Verbindungsaufbau.
# Ohne Angabe: true bei Port 465, sonst STARTTLS.
# SMTP_SECURE=false

# Absender der Benachrichtigung. Muss zum SMTP-Konto passen,
# sonst greifen SPF/DKIM nicht und die Mail landet im Spam.
MAIL_FROM="Limit Breakers" <info@limit-breakers.eu>

# Empfänger der Formularanfragen (aktuell Test-Adresse)
MAIL_TO=glowreel.enrico@gmail.com

# --- Hinweis Gmail ---
# Gmail als Versender braucht ein App-Passwort (nicht das Kontopasswort)
# und 2FA am Konto:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
